{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/hooks/rtk-rewrite.sh"
          },
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/hooks/bash-auto-allow.sh"
          },
          {
            "type": "command",
            "command": "{{CLAUDE_HOME}}/hooks/git-guard-hook.sh"
          }
        ]
      }
    ]
  },
  "language": "한국어",
  "effortLevel": "high"
}
